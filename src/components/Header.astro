---
import { siteConfig } from '../config/site';
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand">
      {/*
        Your logo already lives at public/images/logo.png and is used
        here. Swap that file for a new version any time — no code
        changes needed. See the README for details.
      */}
      <img
        src="/images/logo.png"
        alt={`${siteConfig.businessName} logo`}
        class="site-header__logo"
        width="64"
        height="64"
      />
      <span class="site-header__name">{siteConfig.businessName}</span>
    </a>
  </div>
</header>

<style>
  .site-header {
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    padding-block: 0.85rem;
  }

  .site-header__brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--color-text);
  }

  .site-header__logo {
    width: 3rem;
    height: 3rem;
    object-fit: contain;
    border-radius: 50%;
  }

  .site-header__name {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
  }

  @media (min-width: 40rem) {
    .site-header__name {
      font-size: 1.65rem;
    }
  }
</style>
